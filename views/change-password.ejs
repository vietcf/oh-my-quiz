<section class="panel auth-panel">
  <div class="panel-head">
    <div>
      <p class="eyebrow">Tài khoản</p>
      <h1>Đổi mật khẩu</h1>
      <p>Cập nhật mật khẩu đăng nhập cho tài khoản <strong><%= currentUser.display_name %></strong>.</p>
    </div>
    <div class="actions">
      <a class="btn secondary" href="/">Quay lại</a>
    </div>
  </div>

  <% if (typeof error === 'string' && error) { %>
    <div class="empty auth-error"><%= error %></div>
  <% } %>

  <% if (typeof success === 'string' && success) { %>
    <div class="empty auth-success"><%= success %></div>
  <% } %>

  <form method="POST" action="/account/password" class="form auth-form">
    <label>
      Mật khẩu hiện tại
      <input type="password" name="current_password" required autocomplete="current-password" />
    </label>
    <label>
      Mật khẩu mới
      <input type="password" name="new_password" required minlength="6" autocomplete="new-password" />
    </label>
    <label>
      Xác nhận mật khẩu mới
      <input type="password" name="confirm_password" required minlength="6" autocomplete="new-password" />
    </label>
    <div class="actions">
      <button class="btn" type="submit">Lưu mật khẩu mới</button>
    </div>
  </form>
</section>
