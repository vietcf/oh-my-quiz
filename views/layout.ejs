<!doctype html>
<html lang="vi">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title><%= title || 'Quiz Simulator' %></title>
  <link rel="stylesheet" href="/styles.css" />
  <script defer src="/app.js"></script>
</head>
<body>
  <div class="container">
    <header class="topbar">
      <div class="brand">
        <strong>Quiz Simulator</strong>
        <span>Node.js + SQLite</span>
      </div>
      <nav class="nav">
        <% if (currentUser) { %>
          <a class="btn secondary" href="/">Trang ch&#7911;</a>
          <a class="btn secondary" href="/practice/new">Thi th&#7917;</a>
          <a class="btn secondary" href="/attempts/history">L&#7883;ch s&#7917; thi</a>
          <a class="btn secondary" href="/account/password">&#272;&#7893;i m&#7853;t kh&#7849;u</a>
          <% if (isAdmin) { %>
            <a class="btn secondary" href="/exams/new">T&#7841;o b&#224;i thi</a>
            <a class="btn secondary" href="/admin/users">Qu&#7843;n l&#253; user</a>
          <% } %>
          <form method="POST" action="/logout">
            <button class="btn secondary" type="submit">&#272;&#259;ng xu&#7845;t <%= currentUser.display_name %></button>
          </form>
        <% } else { %>
          <a class="btn secondary" href="/login">&#272;&#259;ng nh&#7853;p</a>
        <% } %>
      </nav>
    </header>

    <main>
      <%- body %>
    </main>
  </div>
</body>
</html>
